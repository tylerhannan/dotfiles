#!/usr/bin/env bash
#
# .macos — macOS system preferences, captured from the live machine so a new
# Mac matches this one. Re-capture after changing System Settings by re-reading
# the relevant `defaults` domains (see the keys below) and updating this file.
#
# Everything here is user-domain (no sudo) and reversible via System Settings.
# install.sh offers to run this; or run it directly:
#   ./.macos
#
# A logout/restart is needed for some of these (Dark mode, trackpad) to fully
# take effect.

set -uo pipefail

# Close System Settings so it doesn't overwrite changes on exit.
osascript -e 'tell application "System Settings" to quit' 2>/dev/null || true

###############################################################################
# Appearance                                                                  #
###############################################################################

# Dark mode.
defaults write NSGlobalDomain AppleInterfaceStyle -string "Dark"

###############################################################################
# Dock                                                                        #
###############################################################################

# Auto-hide, with small icons and no magnification.
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock tilesize -int 16
defaults write com.apple.dock largesize -int 16
defaults write com.apple.dock magnification -bool false

# Minimize windows into their app icon; don't show recent apps.
defaults write com.apple.dock minimize-to-application -bool true
defaults write com.apple.dock show-recents -bool false

# Don't reorder Spaces by most-recent use.
defaults write com.apple.dock mru-spaces -bool false

# Bottom-right hot corner: disabled.
defaults write com.apple.dock wvous-br-corner -int 1
defaults write com.apple.dock wvous-br-modifier -int 0

###############################################################################
# Trackpad & pointing                                                         #
###############################################################################

# Tap to click (built-in + Bluetooth trackpads, and the global flag).
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# Disable the three-finger-tap lookup gesture.
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerTapGesture -int 0
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerTapGesture -int 0

# Tracking speed.
defaults write NSGlobalDomain com.apple.trackpad.scaling -float 0.875

###############################################################################
# Finder                                                                      #
###############################################################################

# Column view by default ("clmv"; list = "Nlsv", icon = "icnv", gallery = "glyv").
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"

# Show all filename extensions.
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Show disks/volumes on the desktop (but not mounted servers).
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool true
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool true
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool true
defaults write com.apple.finder ShowMountedServersOnDesktop -bool false

# New Finder windows open to Recents/All My Files.
defaults write com.apple.finder NewWindowTarget -string "PfAF"

###############################################################################
# Menu bar                                                                    #
###############################################################################

# Analog menu-bar clock.
defaults write com.apple.menuextra.clock IsAnalog -bool true

###############################################################################
# Apply                                                                       #
###############################################################################

for app in "Finder" "Dock" "SystemUIServer"; do
  killall "${app}" >/dev/null 2>&1 || true
done

echo "macOS defaults applied. Log out/restart for Dark mode and trackpad changes to fully take effect."
